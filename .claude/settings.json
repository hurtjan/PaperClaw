{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python3 scripts/ingest/ingest.py --dry-run)",
      "Bash(.venv/bin/python3 scripts/ingest/ingest.py)",
      "Bash(.venv/bin/python3 scripts/query/duckdb_query.py *)",
      "Bash(.venv/bin/python3 scripts/query/corpus.py *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check_onboarding.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
