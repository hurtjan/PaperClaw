{
  "permissions": {
    "allow": [
      "Bash(python3 scripts/py.py scripts/ingest/* *)",
      "Bash(python3 scripts/py.py scripts/link/* *)",
      "Bash(python3 scripts/py.py scripts/query/* *)",
      "Bash(python3 scripts/py.py scripts/build/* *)",
      "Bash(python3 scripts/py.py scripts/enrich/* *)",
      "Bash(python scripts/py.py scripts/ingest/* *)",
      "Bash(python scripts/py.py scripts/link/* *)",
      "Bash(python scripts/py.py scripts/query/* *)",
      "Bash(python scripts/py.py scripts/build/* *)",
      "Bash(python scripts/py.py scripts/enrich/* *)",
      "Bash(python3 -m venv .venv)",
      "Bash(python -m venv .venv)",
      "Bash(python3 scripts/pip_install.py install *)",
      "Bash(python scripts/pip_install.py install *)",
      "Bash(python3 scripts/hooks/*)",
      "Bash(python scripts/hooks/*)",
      "Bash(python3 scripts/test/test_helpers.py *)",
      "Bash(python scripts/test/test_helpers.py *)",
      "Bash(mkdir -p data/*)",
      "Bash(mkdir -p pdf-staging)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedHosts": ["extensions.duckdb.org"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/hooks/check_onboarding.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
