{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python3 scripts/ingest/* *)",
      "Bash(.venv/bin/python3 scripts/link/* *)",
      "Bash(.venv/bin/python3 scripts/query/* *)",
      "Bash(.venv/bin/python3 scripts/build/* *)",
      "Bash(.venv/bin/python3 scripts/enrich/* *)",
      "Bash(python3 -m venv .venv)",
      "Bash(.venv/bin/pip install -r requirements.txt)",
      "Bash(bash scripts/hooks/*)",
      "Bash(mkdir -p data/*)",
      "Bash(mkdir -p pdf-staging)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedHosts": ["extensions.duckdb.org"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check_onboarding.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
