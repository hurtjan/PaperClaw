{
  "claudeMdExcludes": [
    "../CLAUDE.md",
    "../.claude/**",
    "**/PaperClaw/CLAUDE.md",
    "**/PaperClaw/.claude/**"
  ],
  "permissions": {
    "allow": [
      "Bash(python3 scripts/py.py scripts/query/* *)",
      "Bash(python scripts/py.py scripts/query/* *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/guard_db_read.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
